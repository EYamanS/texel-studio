# ── AI Provider (choose one or both) ──

# Option 1: Gemini API key
# GEMINI_API_KEY=your_gemini_api_key

# Option 2: Google Cloud service account file (Vertex AI)
# GOOGLE_SERVICE_ACCOUNT_JSON=service-account.json

# Option 3: Service account JSON content as env var (for Railway/Docker)
# GOOGLE_SERVICE_ACCOUNT_JSON_CONTENT={"type":"service_account","project_id":"...","private_key":"...",...}

# Option 3: OpenAI
# OPENAI_API_KEY=your_openai_api_key

# Option 4: OpenAI-compatible server (Llama.cpp, VLLM, LM Studio, OpenRouter, etc.)
# Set OPENAI_BASE_URL to your endpoint and list the model names you want exposed in the UI.
# OPENAI_API_KEY is optional for local servers; required for hosted ones like OpenRouter.
# OPENAI_BASE_URL=http://localhost:8080/v1
# OPENAI_MODELS=llama-3.1-8b-instruct,qwen2.5-coder-7b

# ── Optional: Tracing (choose one or both) ──

# LangSmith
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=your_langsmith_key
# LANGSMITH_PROJECT=texel-studio

# PostHog LLM Analytics
# POSTHOG_API_KEY=phc_your_project_api_key
# POSTHOG_HOST=https://us.i.posthog.com

# ── Optional: API key auth ──
# Set to require x-api-key header on all requests (useful when hosting publicly)
# API_KEY=your_secret_key

# ── Optional: Redis for job queue (enables concurrent generations) ──
# Without Redis, the engine handles one generation at a time (fine for self-hosted)
# With Redis, run worker.py alongside server.py for parallel generation
# REDIS_URL=redis://localhost:6379

# ── Optional: S3-compatible object storage (shared files across workers) ──
# Without this, files are stored on the local filesystem (fine for self-hosted)
# Railway Object Store, AWS S3, Cloudflare R2, MinIO, etc. all work
# ENDPOINT=https://your-s3-endpoint
# ACCESS_KEY_ID=your_access_key
# SECRET_ACCESS_KEY=your_secret_key
# BUCKET=your_bucket_name
